{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "Application log dashboard for DevOps course apps",
  "editable": true,
  "panels": [
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showTime": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "{app=~\"devops-.*\"}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "All Application Logs",
      "type": "logs"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 2,
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum by (app) (rate({app=~\"devops-.*\"}[1m]))",
          "legendFormat": "{{app}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Request Rate (logs/s by app)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 3,
      "options": { "enableLogDetails": true, "showTime": true, "sortOrder": "Descending" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "{app=~\"devops-.*\"} | json | level=\"ERROR\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Error Logs",
      "type": "logs"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "id": 4,
      "options": { "legend": { "displayMode": "list", "placement": "right" }, "pieType": "pie" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum by (level) (count_over_time({app=~\"devops-.*\"} | json [5m]))",
          "legendFormat": "{{level}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Log Level Distribution (5m)",
      "type": "piechart"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["loki", "devops"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "name": "DS_LOKI",
        "query": "loki",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "title": "App Logs Dashboard",
  "uid": "app-logs-dashboard",
  "version": 1
}
