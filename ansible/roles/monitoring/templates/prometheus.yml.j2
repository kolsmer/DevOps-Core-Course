global:
  scrape_interval: {{ monitoring_prometheus_scrape_interval }}
  evaluation_interval: {{ monitoring_prometheus_scrape_interval }}

scrape_configs:
  - job_name: prometheus
    static_configs:
      - targets: ["localhost:{{ monitoring_prometheus_port }}"]

  - job_name: app
    metrics_path: /metrics
    static_configs:
      - targets: ["app-python:{{ monitoring_app_port }}"]

  - job_name: loki
    metrics_path: /metrics
    static_configs:
      - targets: ["loki:{{ monitoring_loki_port }}"]

  - job_name: grafana
    metrics_path: /metrics
    static_configs:
      - targets: ["grafana:{{ monitoring_grafana_port }}"]
